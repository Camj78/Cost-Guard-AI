{
  "name": "costguardai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/run-golden.ts",
    "test:webhook": "tsx tests/github-webhook.test.ts",
    "test:resilience": "tsx tests/github-webhook-resilience.test.ts",
    "e2e": "playwright test",
    "audit": "pnpm audit --prod",
    "golden": "tsx tests/run-golden.ts",
    "shot:once": "node scripts/screenshot-loop.mjs",
    "shot:loop": "PASSES=2 node scripts/screenshot-loop.mjs",
    "shot:clean": "node scripts/clean-screenshots.mjs",
    "build:cli": "npm run build --prefix packages/cli",
    "test:cli": "node packages/cli/scripts/test-golden.mjs",
    "test:risk-score": "tsx tests/run-risk-score.ts",
    "test:explainability": "tsx tests/explainability-test.ts",
    "test:cost-impact": "tsx tests/cost-impact.test.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-tiktoken": "^1.0.21",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.358.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@next/swc-darwin-x64": "16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer",
      "esbuild"
    ],
    "overrides": {
      "@fastify/otel>minimatch": "^10.2.4"
    }
  }
}
