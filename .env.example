# ─────────────────────────────────────────────────
# CostGuardAI — Environment Variables
# ─────────────────────────────────────────────────
#
# Copy this file to .env and fill in values for production deployment.

# App URL — used for OpenGraph metadata + Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth callback redirects — set to canonical production domain in Vercel env vars
# Must NOT have a trailing slash
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (required for auth + dashboard) ────
# Get these from: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Payments (Stripe) ──────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_ID=             # Monthly Pro: $29/month recurring price ID
# STRIPE_ANNUAL_PRICE_ID=      # Annual Pro: $199/year — create in Stripe Dashboard → Products → Add price → Recurring → Yearly
