# ─────────────────────────────────────────────────
# CostGuardAI — Environment Variables
# ─────────────────────────────────────────────────
#
# Copy this file to .env and fill in values for production deployment.

# App URL — used for OpenGraph metadata + Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth callback redirects — set to canonical production domain in Vercel env vars
# Must NOT have a trailing slash
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (required for auth + dashboard) ────
# Get these from: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Analytics (PostHog) ────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Payments (Stripe) ──────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
#
# Plan-specific price IDs — create in Stripe Dashboard → Products → Add price → Recurring
# STRIPE_PRICE_PRO_MONTHLY=    # Pro: $29/month
# STRIPE_PRICE_PRO_YEARLY=     # Pro: $290/year
# STRIPE_PRICE_TEAM_MONTHLY=   # Team: $99/month (backend-ready; UI not yet exposed)
# STRIPE_PRICE_TEAM_YEARLY=    # Team: $999/year (backend-ready; UI not yet exposed)

# ─── Supabase Service Role (GitHub webhook dedup) ────
# SUPABASE_URL=                # Same value as NEXT_PUBLIC_SUPABASE_URL (no NEXT_PUBLIC prefix)
# SUPABASE_SERVICE_ROLE_KEY=   # Supabase project → Settings → API → service_role key (keep secret — server only)

# ─── GitHub Integration ─────────────────────────────
# GITHUB_WEBHOOK_SECRET=       # Secret set in GitHub webhook settings (used to verify signatures)
# GITHUB_TOKEN=                # GitHub PAT (repo + write:discussion scopes) — local dev / PAT fallback

# GitHub App credentials — required for /api/github/repos (repo list) and PR bot App auth
# GITHUB_APP_ID=               # Numeric App ID from GitHub App settings
# GITHUB_APP_PRIVATE_KEY=      # RSA private key PEM (literal \n separators are fine; Vercel format)

# Public — used to build the install URL (falls back to "costguardai")
# NEXT_PUBLIC_GITHUB_APP_SLUG= # GitHub App slug (the name in github.com/apps/<slug>)

# Setup URL to configure in your GitHub App settings:
#   https://<your-domain>/api/github/install/callback
# GitHub redirects here after the user installs the App, passing ?installation_id=...

# ─── Observability (Sentry) ─────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=      # Sentry DSN — public (used by client + server fallback)
# SENTRY_DSN=                  # Sentry DSN — server-only (takes priority over NEXT_PUBLIC_SENTRY_DSN)
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=              # Optional; populated automatically by CI or Sentry webpack plugin
