# ─────────────────────────────────────────────────
# CostGuardAI — Environment Variables
# ─────────────────────────────────────────────────
#
# Copy this file to .env and fill in values for production deployment.

# App URL — used for OpenGraph metadata + auth callback redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (required for auth + dashboard) ────
# Get these from: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Payments (Stripe) ──────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
