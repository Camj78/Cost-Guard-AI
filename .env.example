# ─────────────────────────────────────────────────
# CostGuardAI V1 — Environment Variables
# ─────────────────────────────────────────────────
#
# V1 is entirely client-side. No env vars are required to run locally.
# Copy this file to .env and fill in values for production deployment.

# App URL — used for OpenGraph metadata base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── V2+ (not needed for V1) ────────────────────

# Auth (Clerk)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Payments (Stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (SQLite / Postgres for V2 analytics)
# DATABASE_URL=
